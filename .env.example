# Foray Planner configuration - all settings via environment variables.
# Copy to .env and edit. Nested keys use __ delimiter.

# Home location (search center)
FORAY_HOME__NAME=Home
FORAY_HOME__LAT=47.6062
FORAY_HOME__LNG=-122.3321
FORAY_HOME__RADIUS_KM=150

# Region granularity
FORAY_CELL_DEG=0.25

# Ingest parameters
FORAY_INGEST__SINCE_YEAR=2015
FORAY_INGEST__QUALITY_GRADE=research
FORAY_INGEST__RECENT_WEEKS=4

# No target-genus config here (issue #79) - `foray genera-refresh` keeps the full Fungi
# catalog synced, and users pick targets per-device in the search UI.

# Coverage regions for state-level pre-fetch (JSON array)
# FORAY_COVERAGE='[{"name": "Washington", "place_id": 46}, {"name": "Oregon", "place_id": 30}, {"name": "Idaho", "place_id": 25}]'

# Database: standard libpq env vars (not FORAY_ prefixed)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=foray
# PGPASSWORD=foray
# PGDATABASE=foray

# RIDB (campgrounds)
# RIDB_API_KEY=your-key-here
